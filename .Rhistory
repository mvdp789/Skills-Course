ymax = (mean_value + (2*se_value)),
width = 0.2),
size = 1.6,
position = position_dodge(0.7)) +
geom_point(aes(x = Group, y = adjAreaWest1), size = 6, ShorterRCAIAdj) +
xlab("\nTreatment") +
ylab("Level of RCAI Binding (16-bit Greyscale)\n") +
my_theme()+
theme(axis.text = element_text(size = 26, colour = "black"),
axis.title = element_text(size = 32, face = "bold"))+
scale_y_continuous(limits = c(-4000, 106000)) +
scale_fill_manual(values = c("#009C59", "#184A00"))+
annotate("segment", x = 1, xend= 1, y = 100000, yend = 97000, size = 1.6) +
annotate("segment", x = 2, xend = 2, y = 100000, yend = 97000, size = 1.6) +
annotate("segment", x = 1, xend = 2, y = 100000, yend = 100000, size = 1.6) +
annotate("text", x = 1.5, y = 103000, label = "NS p = 0.06845", size = 16))
ggsave("RCAIshortgraph.png", width = 14, height = 12, dpi = 300)
